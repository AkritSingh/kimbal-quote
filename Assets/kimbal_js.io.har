            "compression": 93509,
            "text": "gsap.registerPlugin(ScrollTrigger, ScrollSmoother);\n\n// console.log(\"hello\");\n$(\"#yearBtn\").click(function () { \n        $(\"#year-list\").toggle();\n    });\n\nwindow.addEventListener('load', function () {\n  document.body.style.opacity = '1';\n});\n\nlet body = document.body;\n\nif (!body.classList.contains('page-id-1463')\n   && \n!body.classList.contains('page-id-576')\n  && \n!body.classList.contains('page-id-1052')\n\n) \n  \n  {\n  // !smooth scrolling\n  var smoother = ScrollSmoother.create({\n    wrapper: \"#smooth-wrapper\",\n    content: \"#smooth-content\",\n    smooth: 2,\n    effects: true,\n    preventDefault: true,\n    smoothTouch: false,\n    ignoreMobileResize: true,\n  });\n\n  ScrollTrigger.refresh();\n}\n\n\n\n\n\n\n\n//! Parallax effect to image\n\ngsap.utils.toArray(\".parallax_image\").forEach(function (container) {\n  // let image = container.querySelector(\"img\");\n\n  let tl = gsap.timeline({\n    scrollTrigger: {\n      trigger: container,\n      scrub: true,\n      pin: false,\n    },\n  });\n  tl.from(container, {\n    // scaleY: 1.6,\n    transformOrigin: \"50% 50%\",\n    yPercent: -20,\n    ease: \"none\",\n  }).to(container, {\n    transformOrigin: \"50% 50%\",\n    // scaleY: 1.6,\n    yPercent: 7,\n    ease: \"none\",\n  });\n});\n\n//! Parallax effect to text\n\ngsap.utils.toArray(\".parallax_text\").forEach(function (container) {\n  // let image = container.querySelector(\"img\");\n\n  let tl = gsap.timeline({\n    scrollTrigger: {\n      trigger: container,\n      scrub: true,\n      pin: false,\n    },\n  });\n  tl.from(container, {\n    // scaleY: 1.6,\n    transformOrigin: \"50% 50%\",\n    yPercent: -20,\n    ease: \"none\",\n  }).to(container, {\n    transformOrigin: \"50% 50%\",\n    // scaleY: 1.6,\n    yPercent: 10,\n    ease: \"none\",\n  });\n});\n\n// !dropdown button mobile \n\n\nlet dropDownArrowBtn = document.querySelectorAll('.dropDownBtnArrow');\n\n\ndropDownArrowBtn.forEach(function (el) {\n\n\n  el.addEventListener('click', function (e) {\n\n    console.log('clicked arrow');\n\n\n    e.stopPropagation();\n\n    this.parentElement.classList.toggle('active')\n    // this.parentElement.parentElement.querySelector('.dropDoownBtn2').classList.toggle('active')\n\n    this.parentElement.parentElement.querySelector('.subList').classList.toggle('active')\n\n\n  })\n\n})\n\n\n// !nilm page popup \n\n// request demo \n\nlet requestForDemoBtn = document.querySelector('#requestForDemo');\nlet requestForDemoPopUp = document.querySelector('.requestForDemo')\nlet requestForDemoCloseBtn = document.querySelector('.requestForDemo .close')\n\nrequestForDemoBtn?.addEventListener('click', function (e) {\n\n  e.preventDefault()\n\n  requestForDemoPopUp.style.display = 'flex';\n  requestForDemoPopUp.parentElement.style.display = 'block';\n  setTimeout(() => {\n    requestForDemoPopUp.style.opacity = 1;\n    requestForDemoPopUp.parentElement.style.opacity = 1;\n  }, 100);\n\n\n})\n\nrequestForDemoCloseBtn?.addEventListener('click', function () {\n\n  requestForDemoPopUp.style.opacity = 0;\n  requestForDemoPopUp.parentElement.style.opacity = 0;\n  setTimeout(() => {\n    requestForDemoPopUp.style.display = 'none';\n    requestForDemoPopUp.parentElement.style.display = 'none';\n  }, 300);\n\n})\n\n\n// Order your kit\n\n\nlet orderYourKitBtn = document.querySelector('#orderYourKit');\nlet orderYourKitPopUp = document.querySelector('.orderYourKit')\nlet orderYourKitCloseBtn = document.querySelector('.orderYourKit .close')\n\norderYourKitBtn?.addEventListener('click', function (e) {\n\n  e.preventDefault()\n\n  orderYourKitPopUp.style.display = 'flex';\n  orderYourKitPopUp.parentElement.style.display = 'block';\n  setTimeout(() => {\n    orderYourKitPopUp.style.opacity = 1;\n    orderYourKitPopUp.parentElement.style.opacity = 1;\n  }, 100);\n\n\n})\n\norderYourKitCloseBtn?.addEventListener('click', function () {\n\n  orderYourKitPopUp.style.opacity = 0;\n  orderYourKitPopUp.parentElement.style.opacity = 0;\n  setTimeout(() => {\n    orderYourKitPopUp.style.display = 'none';\n    orderYourKitPopUp.parentElement.style.display = 'none';\n  }, 300);\n\n})\n\n\n\n// joinTheWaitingList \n\n\nlet joinTheWaitingListBtn = document.querySelector('#joinTheWaitingList');\nlet joinTheWaitingListPopUp = document.querySelector('.joinTheWaitingList')\nlet joinTheWaitingListCloseBtn = document.querySelector('.joinTheWaitingList .close')\n\njoinTheWaitingListBtn?.addEventListener('click', function (e) {\n\n  e.preventDefault()\n\n  joinTheWaitingListPopUp.style.display = 'flex';\n  joinTheWaitingListPopUp.parentElement.style.display = 'block';\n  setTimeout(() => {\n    joinTheWaitingListPopUp.style.opacity = 1;\n    joinTheWaitingListPopUp.parentElement.style.opacity = 1;\n  }, 100);\n\n\n})\n\njoinTheWaitingListCloseBtn?.addEventListener('click', function () {\n\n  joinTheWaitingListPopUp.style.opacity = 0;\n  joinTheWaitingListPopUp.parentElement.style.opacity = 0;\n  setTimeout(() => {\n    joinTheWaitingListPopUp.style.display = 'none';\n    joinTheWaitingListPopUp.parentElement.style.display = 'none';\n  }, 300);\n\n})\n\n\n\n\n\n\n\n\n\n// !smart meters popUp \n\nlet allSmartMeterSLider = document.querySelectorAll('.smart_meters-slides .container_3 .popUpSlide')\n\n\n\nallSmartMeterSLider.forEach(function (el) {\n\n  el.addEventListener('click', function (e) {\n\n\n    let popUpOlay = document.querySelector('.smartMeters_popUp').parentElement;\n    let popUpContaienr = document.querySelector('.popUp-overlay .smartMeters_popUp')\n\n\n\n    let popUpHead = this.querySelector('.container_3 .popUpSlide h1').innerHTML;\n    let popUpImageUrl = this.querySelector('.container_3 .popUpSlide img').src;\n    let popUpLabel1 = this.dataset.label1;\n    let popUpLabel2 = this.dataset.label2;\n    let popUpLabel3 = this.dataset.label3;\n    let popUpLabel4 = this.dataset.label4;\n    let popUpLabel5 = this.dataset.label5;\n\n\n    let popUpContent1 = this.dataset.content1;\n    let popUpContent2 = this.dataset.content2;\n    let popUpContent3 = this.dataset.content3;\n    let popUpContent4 = this.dataset.content4;\n    let popUpContent5 = this.dataset.content5;\n\n\n    let closeBtn = popUpContaienr.querySelector('.close');\n\n    console.log(closeBtn);\n\n\n\n\n\n\n    //! popUp elements \n\n    let popUpHeadElement = popUpContaienr.querySelector('.c1 .head h1');\n    let popUpImageElement = popUpContaienr.querySelector('.c2 img');\n\n    if (mobile.matches) {\n      popUpImageElement = popUpContaienr.querySelector('.c1 img');\n    }\n\n    let popUpLabel1Element = popUpContaienr.querySelector('.c1 .content .row1 h1');\n    let popUpLabel2Element = popUpContaienr.querySelector('.c1 .content .row2 h1');\n    let popUpLabel3Element = popUpContaienr.querySelector('.c1 .content .row3 h1');\n    let popUpLabel4Element = popUpContaienr.querySelector('.c1 .content .row4 h1');\n    let popUpLabel5Element = popUpContaienr.querySelector('.c1 .content .row5 h1');\n\n    let popupContent1Element = popUpContaienr.querySelector('.c1 .content .row1 p');\n    let popupContent2Element = popUpContaienr.querySelector('.c1 .content .row2 p');\n    let popupContent3Element = popUpContaienr.querySelector('.c1 .content .row3 p');\n    let popupContent4Element = popUpContaienr.querySelector('.c1 .content .row4 p');\n    let popupContent5Element = popUpContaienr.querySelector('.c1 .content .row5 p');\n\n\n    popUpHeadElement.textContent = popUpHead;\n    popUpImageElement.src = popUpImageUrl;\n\n    popUpLabel1Element.textContent = popUpLabel1;\n    popUpLabel2Element.textContent = popUpLabel2;\n    popUpLabel3Element.textContent = popUpLabel3;\n    popUpLabel4Element.textContent = popUpLabel4;\n    popUpLabel5Element.textContent = popUpLabel5;\n\n    popupContent1Element.textContent = popUpContent1;\n    popupContent2Element.textContent = popUpContent2;\n    popupContent3Element.textContent = popUpContent3;\n    popupContent4Element.innerHTML = popUpContent4;\n    if (popUpContent5) {\n\n      popupContent5Element.innerHTML = popUpContent5;\n    }\n\n\n\n    // console.log(popUpLabel1, popUpLabel2, popUpLabel3, popUpLabel4);\n    // console.log(popUpContent1, popUpContent2, popUpContent3, popUpContent4);\n\n\n\n\n\n    popUpOlay.style.display = 'block';\n\n\n\n    popUpContaienr.style.display = 'flex';\n    setTimeout(() => {\n      popUpOlay.style.opacity = 1;\n      popUpContaienr.style.opacity = 1;\n    }, 300);\n\n\n    closeBtn.addEventListener('click', function () {\n      popUpOlay.style.opacity = 0;\n\n\n\n      popUpContaienr.style.opacity = 0;\n      setTimeout(() => {\n        popUpOlay.style.display = 'none';\n        popUpContaienr.style.display = 'none';\n      }, 300);\n\n      // Clear all content\n\n\n      setTimeout(() => {\n\n        popUpHeadElement.textContent = '';\n        popUpImageElement.src = '';\n\n        popUpLabel1Element.textContent = '';\n        popUpLabel2Element.textContent = '';\n        popUpLabel3Element.textContent = '';\n        popUpLabel4Element.textContent = '';\n        popUpLabel5Element.textContent = '';\n\n        popupContent1Element.textContent = '';\n        popupContent2Element.textContent = '';\n        popupContent3Element.textContent = '';\n        popupContent4Element.textContent = '';\n        popupContent5Element.textContent = '';\n      }, 300);\n    })\n\n  })\n\n\n})\n\n\n\nlet allApplyBtn = document.querySelectorAll('.jobApplyNow');\nlet applyJobPopUp = document.querySelector('.jobApplyPopUp')\nlet allApplyCloseBtn = document.querySelector('.jobApplyPopUp .closeBtn')\n\nallApplyBtn.forEach(function (el) {\n\n  el.addEventListener('click', function (e) {\n    e.preventDefault();\n\n\n    applyJobPopUp.classList.toggle('active')\n\n    setTimeout(() => {\n\n      applyJobPopUp.style.opacity = 1;\n    }, 300);\n\n  })\n\n})\n\nallApplyCloseBtn.addEventListener('click', function () {\n\n\n  applyJobPopUp.style.opacity = 0;\n\n  setTimeout(() => {\n    applyJobPopUp.classList.toggle('active')\n  }, 300);\n\n})\n\n\n\n// gsap.utils.toArray(\".section\").forEach(function (container) {\n\n//   let tl = gsap.timeline({\n\n//     scrollTrigger: {\n//       trigger: container,\n//       scrub: true,\n//       pin: false,\n//     },\n\n//   })\n\n//   .from(container, {\n//     opacity: 0,\n//     background : 'transparent',\n\n//     duration: .5,\n\n//     ease: \"power2.out\",\n\n//   })\n\n// });\n\n// !desktop mobile condition\n\nlet mobile = window.matchMedia(\"(max-width: 768px)\");\nlet desktop = window.matchMedia(\"(min-width: 768px)\");\n\nconst swiper = new Swiper(\".swiper-home\", {\n  slidesPerView: 'auto',\n  spaceBetween: 20,\n  autoplay: true,\n  // freeMode: true,\n  navigation: {\n    nextEl: \".swiper-button-next\",\n    prevEl: \".swiper-button-prev\",\n  },\n  breakpoints: {\n    768: {\n      slidesPerView: 'auto',\n      spaceBetweenSlides: 0,\n    },\n  },\n});\n\n\n// var swiper2 = new Swiper(\" .swiper2\", {\n//   slidesPerView: 'auto',\n//    spaceBetween: 30,\n//    autoplay: true,\n\n//    // freeMode: true,\n\n//    breakpoints: {\n//      768: {\n//        slidesPerView:'auto' ,\n//        spaceBetweenSlides: 0,\n//      },\n//    },\n//  });\n\n\n\n\n$(\".ourHeroslinks  > div\").slick({\n  infinite: true,\n  slidesToShow: 5,\n  slidesToScroll: 1,\n\n  arrows: false,\n  variableWidth: true,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 3,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n\n\n\n// !mobile menu dropdown\n\nlet dropDownBtn = document.querySelector(\"#dropDownBtn\");\nlet dropDownList = document.querySelectorAll(\".dropDown\");\nlet dropDownContainer = document.querySelector(\".menuBar .list .c1\");\n\ndropDownBtn?.addEventListener(\"click\", () => {\n  dropDownContainer.classList.toggle(\"active\");\n\n  dropDownBtn.classList.toggle(\"active\");\n  dropDownList.forEach((el) => {\n    // console.log(el);\n    el.classList.toggle(\"active\");\n  });\n});\n\n\nlet dropDown2 = document.querySelectorAll('.dropDoownBtn2')\n\ndropDown2.forEach(function (el) {\n\n  el.addEventListener('click', function (e) {\n    this.parentElement.classList.toggle('active')\n    this.parentElement.querySelector('.dropDoownBtn2').classList.toggle('active')\n\n    this.parentElement.querySelector('.subList').classList.toggle('active')\n\n\n  })\n\n})\n\n\n\n\n\n\n\n//! remove line break\n\nif (mobile.matches) {\n\n  // console.log('mobile');\n\n\n  const homeParagraphsCard5 = document.querySelectorAll(\".card_5 .links p\");\n\n  const licensesCCM = document.querySelectorAll(\".licenses-ccmi div h1\");\n  const licensesCertified = document.querySelectorAll(\".licenses-certified h3\");\n  const contactUsBanner = document.querySelectorAll(\".contactUs-banner h3\");\n  // const homeText = document.querySelectorAll(\".card_1 > div h3\");\n\n\n  const removeBreakInText = document.querySelectorAll('.removeTextBreak');\n\n  removeBreakInText.forEach((p) => {\n    p.innerHTML = p.innerHTML.replace(/<br\\s*\\/?>/gi, \"\");\n  });\n\n\n\n\n  homeParagraphsCard5.forEach((p) => {\n    p.innerHTML = p.innerHTML.replace(/<br\\s*\\/?>/gi, \"\");\n  });\n  licensesCCM.forEach((p) => {\n    p.innerHTML = p.innerHTML.replace(/<br\\s*\\/?>/gi, \"\");\n  });\n  licensesCertified.forEach((p) => {\n    p.innerHTML = p.innerHTML.replace(/<br\\s*\\/?>/gi, \"\");\n  });\n  contactUsBanner.forEach((p) => {\n    p.innerHTML = p.innerHTML.replace(/<br\\s*\\/?>/gi, \"\");\n  });\n}\n\n// !menubar =======================\n\nlet menuBtn = document.querySelector(\".menuBtn\");\nlet menuList = document.querySelector(\"#menuBar\");\n\nmenuBtn?.addEventListener(\"click\", (e) => {\n  e.preventDefault();\n  menuBtn.classList.toggle(\"active\");\n  menuList.classList.toggle(\"active\");\n\n\n});\n\n\nlet footerNavBtns = document.querySelectorAll(\".navBtn\");\n\n\nfooterNavBtns.forEach((navBtn) => {\n  navBtn.addEventListener(\"click\", (e) => {\n    e.preventDefault();\n    menuBtn.classList.toggle(\"active\");\n    menuList.classList.toggle(\"active\");\n  });\n});\n\n\n\n\n// !sliders\n\n// !our story page ======================\n\n// !growth\n\n$(\".ourStory_growth .slide\").slick({\n  infinite: true,\n  slidesToShow: 2,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 1,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".ourStory_growth .slideNav .prev\").click(function () {\n  $(\".ourStory_growth .slide\").slick(\"slickPrev\");\n});\n$(\".ourStory_growth .slideNav .next\").click(function () {\n  $(\".ourStory_growth .slide\").slick(\"slickNext\");\n});\n\n// !history\n\n$(\".ourStory_history .slides\").slick({\n  infinite: true,\n  slidesToShow: 2,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 1,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".ourStory_history .slideNav .prev\").click(function () {\n  $(\".ourStory_history .slides\").slick(\"slickPrev\");\n});\n$(\".ourStory_history .slideNav .next\").click(function () {\n  $(\".ourStory_history .slides\").slick(\"slickNext\");\n});\n\n\n\n\n\n// !testimony\n\n$(\".ourStory_testimonials .slides\").slick({\n  infinite: true,\n  slidesToShow: 2,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 1,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".ourStory_testimonials .slideNav .prev\").click(function () {\n  $(\".ourStory_testimonials .slides\").slick(\"slickPrev\");\n});\n$(\".ourStory_testimonials .slideNav .next\").click(function () {\n  $(\".ourStory_testimonials .slides\").slick(\"slickNext\");\n});\n\n// ! our Core page ======================\n\n// !our values\n\n$(\".ourCore_values .slides\").slick({\n  infinite: true,\n  slidesToShow: 3,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 1,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".ourCore_values .slideNav .prev\").click(function () {\n  $(\".ourCore_values .slides\").slick(\"slickPrev\");\n});\n$(\".ourCore_values .slideNav .next\").click(function () {\n  $(\".ourCore_values .slides\").slick(\"slickNext\");\n});\n\n// !our DNA\n\n$(\".ourCore_DNA .slides\").slick({\n  infinite: true,\n  slidesToShow: 3,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 1,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".ourCore_DNA .slideNav .prev\").click(function () {\n  $(\".ourCore_DNA .slides\").slick(\"slickPrev\");\n});\n$(\".ourCore_DNA .slideNav .next\").click(function () {\n  $(\".ourCore_DNA .slides\").slick(\"slickNext\");\n});\n\n// !culture values \n\n\n\n$(\".cultureValues .slides\").slick({\n  infinite: true,\n  slidesToShow: 2,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 1,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".cultureValues .slideNav .prev\").click(function () {\n  $(\".cultureValues .slides\").slick(\"slickPrev\");\n});\n$(\".cultureValues .slideNav .next\").click(function () {\n  $(\".cultureValues .slides\").slick(\"slickNext\");\n});\n\n\n\n// !culture conduct \n\n\n\n$(\".cultureConductSlide .slides\").slick({\n  infinite: true,\n  slidesToShow: 2,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 1,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".cultureConductSlide .slideNav .prev\").click(function () {\n  $(\".cultureConductSlide .slides\").slick(\"slickPrev\");\n});\n$(\".cultureConductSlide .slideNav .next\").click(function () {\n  $(\".cultureConductSlide .slides\").slick(\"slickNext\");\n});\n\n\n// !our plants page =============\n\n\n// !block height \n\nif (!mobile.matches) {\n\n\n  const contentElements = document.querySelectorAll('.ourPlants-ZERODefectGoal .c1 .content');\n  const targetElements = document.querySelectorAll('.ourPlants-ZERODefectGoal .c2');\n\n  contentElements.forEach((contentElement, index) => {\n    const contentHeight = contentElement.offsetHeight;\n\n    // Apply the height to the corresponding c2 element\n    if (targetElements[index]) {\n      targetElements[index].style.height = contentHeight + 'px';\n    }\n  });\n\n\n  const contentElements2 = document.querySelectorAll('.contactUs-list .c2');\n  const targetElements2 = document.querySelectorAll('.contactUs-list .c1');\n\n  contentElements2.forEach((contentElement, index) => {\n    const contentHeight = contentElement.offsetHeight;\n\n    // Apply the height to the corresponding c2 element\n    if (targetElements2[index]) {\n      targetElements2[index].style.height = contentHeight + 'px';\n    }\n  });\n\n\n\n}\n\n\n//! ourPlants block Popup\n\n// let ourPlantBlock = document.querySelectorAll(\".ourPlants-blocks .block \");\n\n// ourPlantBlock.forEach(function (block) {\n//   block.addEventListener(\"click\", function (el) {\n//     let popUp = this.querySelector(\".popUp\");\n\n//     if (popUp) {\n//       popUp.classList.add(\"active\");\n//       setTimeout(() => {\n//         popUp.style.opacity = \"1\";\n//       }, 100);\n//     }\n//   });\n// });\n\n// // !close popUp\n\n// let ourPlantBlockCloseBtn = document.querySelectorAll(\n//   \".ourPlants-blocks .block .closeBtn\"\n// );\n\n// ourPlantBlockCloseBtn.forEach(function (element) {\n//   element.addEventListener(\"click\", function (el) {\n//     el.stopPropagation();\n\n//     let popUp = this.parentElement;\n//     console.log(popUp.classList);\n//     popUp.style.opacity = \"0\";\n\n//     setTimeout(() => {\n//       popUp.classList.remove(\"active\");\n//     }, 300);\n//   });\n// });\n\n\n// !our core PopUp \n\n\nlet ourCoreLeadersPopUpContainer = document.querySelector('.ourCore-popUp')\n\n\n\nlet ourCoreLeadersCloseBtn = document.querySelectorAll('.ourCore-popUp .closeBtn')\n\n\nfunction bindClickEvents() {\n\n  let ourCoreLeadersPopUpBtn = document.querySelectorAll('.ourCore_leaders .content .block .text h3')\n\n\n  ourCoreLeadersPopUpBtn.forEach(function (el) {\n\n    el?.addEventListener('click', function (e) {\n\n      e.stopPropagation();\n\n\n\n\n      if (ourCoreLeadersPopUpContainer) {\n\n        ourCoreLeadersPopUpContainer.style.display = 'flex';\n        ourCoreLeadersPopUpContainer.parentElement.style.display = 'block';\n\n        setTimeout(() => {\n          ourCoreLeadersPopUpContainer.style.opacity = \"1\";\n          ourCoreLeadersPopUpContainer.parentElement.style.opacity = \"1\";\n        }, 100);\n\n\n\n        let popUpHead = ourCoreLeadersPopUpContainer.querySelector('h1');\n        let popUpPara = ourCoreLeadersPopUpContainer.querySelector('p');\n        let popUpImage = ourCoreLeadersPopUpContainer.querySelector('.c1 img');\n\n\n        let parentElement = this.parentElement.parentElement;\n\n\n        // console.log(parentElement.parentElement.querySelector('img').src);\n        if (popUpHead && parentElement.querySelector('h1')) {\n\n\n\n          //  popUpHead.innerHTML;\n\n          popUpHead.innerHTML = parentElement.querySelector('h1').innerHTML.replace(/<br\\s*\\/?>/gi, \"\");\n        }\n\n        if (popUpPara && parentElement.querySelector('h2')) {\n          popUpPara.innerHTML = parentElement.querySelector('h2').innerHTML;\n        }\n\n        if (popUpImage && parentElement.parentElement.querySelector('img')) {\n          popUpImage.src = parentElement.parentElement.querySelector('img').src;\n        }\n      }\n    })\n  })\n\n}\n\nbindClickEvents();\n\n$('.ourCore_leaders  .content').on('afterChange', function () {\n  bindClickEvents();\n});\n\n\nourCoreLeadersCloseBtn.forEach(function (el) {\n\n  el.addEventListener('click', function () {\n\n\n    this.parentElement.parentElement.style.opacity = \"0\";\n\n\n    let popUpHead = ourCoreLeadersPopUpContainer.querySelector('h1').innerHTML;\n    let popUpPara = ourCoreLeadersPopUpContainer.querySelector('p').innerHTML;\n    let popUpImage = ourCoreLeadersPopUpContainer.querySelector('.c1 img').innerHTML;\n\n    popUpHead = '';\n    popUpPara = '';\n    popUpImage = '';\n\n\n    setTimeout(() => {\n      this.parentElement.parentElement.style.display = 'none'\n      this.parentElement.parentElement.style.display = 'none'\n\n    }, 300);\n\n\n\n  })\n\n})\n\n\n\n\n// !our Plants distinguishingFactor slider\n\n$(\".ourPlants-distinguishingFactor .slide\").slick({\n  infinite: true,\n  slidesToShow: 2,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 1,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".ourPlants-distinguishingFactor .slideNav .prev\").click(function () {\n  $(\".ourPlants-distinguishingFactor .slide\").slick(\"slickPrev\");\n});\n$(\".ourPlants-distinguishingFactor .slideNav .next\").click(function () {\n  $(\".ourPlants-distinguishingFactor .slide\").slick(\"slickNext\");\n});\n\n// !our core leaders \n\n\n// $('.ourCore_leaders .slick-slide').attr('aria-hidden', 'true');\n\n$(\".ourCore_leaders .content\").slick({\n  infinite: true,\n  slidesToShow: 5,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 2,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".ourCore_leaders  .slideNav .prev\").click(function () {\n  $(\".ourCore_leaders  .content\").slick(\"slickPrev\");\n});\n$(\".ourCore_leaders .slideNav .next\").click(function () {\n  $(\".ourCore_leaders  .content\").slick(\"slickNext\");\n});\n\n\n\n// !faq page\n\n// debounceRefresh for smooth scrolling issue\n\nconst debounceRefresh = (() => {\n  let timeout;\n  return function (callback, delay) {\n    clearTimeout(timeout);\n    timeout = setTimeout(callback, delay);\n  };\n})();\n\nconst faqList = document.querySelectorAll(\".faq-list .block\");\nfaqList.forEach((el) => {\n  el.addEventListener(\"click\", function (e) {\n    e.stopPropagation();\n    smoother.paused(true);\n\n    const isActive = el.classList.contains(\"active\");\n    el.classList.toggle(\"active\", !isActive);\n\n    const delay = isActive ? 700 : 300;\n\n    setTimeout(() => {\n      debounceRefresh(() => {\n        ScrollTrigger.refresh();\n        smoother.paused(false);\n      }, 100);\n    }, delay);\n  });\n});\n\n\n\n\n\n\n// !sub-metering page ==============\n\n// !why us\n\n$(\".sub_metering-whyUs .slides\").slick({\n  infinite: true,\n  slidesToShow: 4,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 1,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".sub_metering-whyUs .slideNav .prev\").click(function () {\n  $(\".sub_metering-whyUs .slides\").slick(\"slickPrev\");\n});\n$(\".sub_metering-whyUs .slideNav .next\").click(function () {\n  $(\".sub_metering-whyUs .slides\").slick(\"slickNext\");\n});\n\n// !clientele =========\n\nconst $slider = $(\".sub_metering-clientele .slides\");\nconst $nav = $(\".sub_metering-clientele .slideNav\");\n\n$slider.on(\"init\", function (event, slick) {\n  const totalSlides = slick.$slides.length;\n  const slidesToShow = slick.options.slidesToShow;\n\n  if (totalSlides <= slidesToShow) {\n    $nav.hide();\n  } else {\n    $nav.show();\n  }\n});\n\n$slider.slick({\n  infinite: true,\n  slidesToShow: 6,\n  slidesToScroll: 1,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  arrows: false,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 2,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".sub_metering-clientele .slideNav .prev\").click(function () {\n  $slider.slick(\"slickPrev\");\n});\n$(\".sub_metering-clientele .slideNav .next\").click(function () {\n  $slider.slick(\"slickNext\");\n});\n\n\n// !advance metering page =============\n\n$(\".advanced_metering-whyChooseUs .slides\").slick({\n  infinite: true,\n  slidesToShow: 4,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 2,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".advanced_metering-whyChooseUs .slideNav .prev\").click(function () {\n  $(\".advanced_metering-whyChooseUs .slides\").slick(\"slickPrev\");\n});\n$(\".advanced_metering-whyChooseUs .slideNav .next\").click(function () {\n  $(\".advanced_metering-whyChooseUs .slides\").slick(\"slickNext\");\n});\n\n// !head End System page ==================\n\n$(\".head_End_System-whyChooseUs .slides\").slick({\n  infinite: true,\n  slidesToShow: 3,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 1,\n        slidesToScroll: 1,\n        infini