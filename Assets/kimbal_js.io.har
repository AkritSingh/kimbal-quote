   {\n        opacity: 0,\n        y: 40,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        delay: 0.1,\n      },\n      \"<\"\n    )\n    .from(\n      block.querySelector(\".slide\"),\n      {\n        opacity: 0,\n        y: 40,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        delay: 0.1,\n      },\n      \"<\"\n    );\n});\n\nlet ourPlantsZERODefectGoal = document.querySelectorAll(\n  \".ourPlants-ZERODefectGoal\"\n);\n\nourPlantsZERODefectGoal.forEach((block) => {\n  let tl = gsap.timeline({\n    scrollTrigger: {\n      trigger: block,\n      // markers: true,\n      start: \"top 60%\",\n      toggleActions: \"play none none none\",\n    },\n  });\n\n  tl.from(block.querySelector(\".c1 .head\"), {\n    opacity: 0,\n    y: 40,\n    duration: 1.2,\n    stagger: 0.2,\n    ease: \"power2.out\",\n    delay: 0.1,\n  })\n    .from(\n      block.querySelector(\" .c1 .content \"),\n      {\n        opacity: 0,\n        y: 40,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        delay: 0.1,\n      },\n      \"<\"\n    )\n\n    .from(\n      block.querySelector(\" .c2\"),\n      {\n        opacity: 0,\n        y: 40,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        delay: 0.1,\n      },\n      \"<\"\n    );\n});\n\nlet ourPlantsSustainableProduction = document.querySelectorAll(\n  \".ourPlants-sustainableProduction\"\n);\n\nourPlantsSustainableProduction.forEach((block) => {\n  let tl = gsap.timeline({\n    scrollTrigger: {\n      trigger: block,\n      // markers: true,\n      start: \"top 60%\",\n      toggleActions: \"play none none none\",\n    },\n  });\n\n  tl.from(block.querySelector(\".c1 .head \"), {\n    opacity: 0,\n    y: 40,\n    duration: 1.2,\n    stagger: 0.2,\n    ease: \"power2.out\",\n    delay: 0.1,\n  })\n    .from(\n      block.querySelector(\" .c1 .content \"),\n      {\n        opacity: 0,\n        y: 40,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        delay: 0.1,\n      },\n      \"<\"\n    )\n\n    .from(\n      block.querySelector(\" .c2\"),\n      {\n        opacity: 0,\n        y: 40,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        delay: 0.1,\n      },\n      \"<\"\n    );\n});\n\n// !thought leadership page\n\nlet thoughtLeadershipBanner = document.querySelectorAll(\n  \".thoughtLeadership-banner\"\n);\n\nthoughtLeadershipBanner.forEach((block) => {\n  let tl = gsap.timeline({\n    scrollTrigger: {\n      trigger: block,\n      // markers: true,\n      start: \"top 60%\",\n      toggleActions: \"play none none none\",\n    },\n  });\n\n  tl.from(block.querySelector(\"h1\"), {\n    opacity: 0,\n    y: 40,\n    duration: 1.2,\n    stagger: 0.2,\n    ease: \"power2.out\",\n    delay: 0.1,\n  })\n    .from(\n      block.querySelector(\" h2 \"),\n      {\n        opacity: 0,\n        y: 40,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        delay: 0.1,\n      },\n      \"<\"\n    )\n\n    .from(\n      block.querySelector(\" h2 img\"),\n      {\n        opacity: 0,\n        y: 40,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        delay: 0.1,\n      },\n      \"<\"\n    )\n    .from(\n      block.querySelector(\" h3\"),\n      {\n        opacity: 0,\n        y: 40,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        delay: 0.1,\n      },\n      \"<\"\n    );\n});\n\nlet thoughtLeadershipList = document.querySelectorAll(\n  \".thoughtLeadership-list\"\n);\n\nthoughtLeadershipList.forEach((block) => {\n  let tl = gsap.timeline({\n    scrollTrigger: {\n      trigger: block,\n      // markers: true,\n      start: \"top 60%\",\n      toggleActions: \"play none none none\",\n    },\n  });\n\n  tl.from(block, {\n    opacity: 0,\n    y: 40,\n    duration: 1.2,\n    stagger: 0.2,\n    ease: \"power2.out\",\n    delay: 0.1,\n  });\n});\n\n//! case Studies page\n\nlet caseStudiesBanner = document.querySelectorAll(\".caseStudies-banner\");\n\ncaseStudiesBanner.forEach((block) => {\n  let tl = gsap.timeline({\n    scrollTrigger: {\n      trigger: block,\n      // markers: true,\n      start: \"top 60%\",\n      toggleActions: \"play none none none\",\n    },\n  });\n\n  tl.from(block.querySelector(\"h1\"), {\n    opacity: 0,\n    y: 40,\n    duration: 1.2,\n    stagger: 0.2,\n    ease: \"power2.out\",\n    delay: 0.1,\n  })\n    .from(\n      block.querySelector(\" h2 \"),\n      {\n        opacity: 0,\n        y: 40,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        delay: 0.1,\n      },\n      \"<\"\n    )\n\n    .from(\n      block.querySelector(\" h2 img\"),\n      {\n        opacity: 0,\n        y: 40,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        delay: 0.1,\n      },\n      \"<\"\n    )\n    .from(\n      block.querySelector(\" h3\"),\n      {\n        opacity: 0,\n        y: 40,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        delay: 0.1,\n      },\n      \"<\"\n    );\n});\n\nlet caseStudiesList = document.querySelectorAll(\".caseStudies-list\");\n\ncaseStudiesList.forEach((block) => {\n  let tl = gsap.timeline({\n    scrollTrigger: {\n      trigger: block,\n      // markers: true,\n      start: \"top 60%\",\n      toggleActions: \"play none none none\",\n    },\n  });\n\n  tl.from(block, {\n    opacity: 0,\n    y: 40,\n    duration: 1.2,\n    stagger: 0.2,\n    ease: \"power2.out\",\n    delay: 0.1,\n  });\n});\n\n// !faq page\n\nlet faqBanner = document.querySelectorAll(\".faq-banner\");\n\nfaqBanner.forEach((block) => {\n  let tl = gsap.timeline({\n    scrollTrigger: {\n      trigger: block,\n      // markers: true,\n      start: \"top 60%\",\n      toggleActions: \"play none none none\",\n    },\n  });\n\n  tl.from(block.querySelector(\"h1\"), {\n    opacity: 0,\n    y: 40,\n    duration: 1.2,\n    stagger: 0.2,\n    ease: \"power2.out\",\n    delay: 0.1,\n  })\n    .from(\n      block.querySelector(\" h2 \"),\n      {\n        opacity: 0,\n        y: 40,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        delay: 0.1,\n      },\n      \"<\"\n    )\n\n    .from(\n      block.querySelector(\" h2 img\"),\n      {\n        opacity: 0,\n        y: 40,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        delay: 0.1,\n      },\n      \"<\"\n    )\n    .from(\n      block.querySelector(\" h3\"),\n      {\n        opacity: 0,\n        y: 40,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        delay: 0.1,\n      },\n      \"<\"\n    );\n});\n\n//! advanced_metering page\n\nlet advanceMeteringMillion = document.querySelectorAll(\n  \".advanced_metering-million\"\n);\n\nif (advanceMeteringMillion) {\n  advanceMeteringMillion.forEach((block) => {\n    let tl = gsap.timeline({\n      scrollTrigger: {\n        trigger: block,\n        // markers: true,\n        start: \"top 60%\",\n        toggleActions: \"play none none none\",\n      },\n    });\n\n    tl.from(block, {\n      opacity: 0,\n      y: 40,\n      duration: 1.2,\n      stagger: 0.2,\n      ease: \"power2.out\",\n      delay: 0.1,\n    })\n      .from(\n        block.querySelector(\".text1\"),\n        {\n          opacity: 0,\n          y: 40,\n          duration: 1.2,\n          stagger: 0.2,\n          ease: \"power2.out\",\n          delay: 0.1,\n        },\n        \"<\"\n      )\n      .from(\n        block.querySelector(\".text2\"),\n        {\n          opacity: 0,\n          y: 40,\n          duration: 1.2,\n          stagger: 0.2,\n          ease: \"power2.out\",\n          delay: 0.1,\n        },\n        \"<\"\n      );\n  });\n}\n\n// !gspa end ====================================\n\n// let faqListG =  document.querySelectorAll(\".faq-list\");\n\n// faqListG.forEach((block) => {\n//   let tl = gsap.timeline({\n//     scrollTrigger: {\n//       trigger: block,\n//       // markers: true,\n//       start: \"top 60%\",\n//       toggleActions: \"play none none none\",\n//     },\n//   });\n\n//   tl.from(block, {\n//     opacity: 0,\n//     y: 40,\n//     duration: 1.2,\n//     stagger: 0.2,\n//     ease: \"power2.out\",\n//     delay: 0.1,\n//   })\n\n// });\n\n// let subMenuBtn = document.querySelectorAll('.menuBar .list ul .link')\n\n// subMenuBtn.forEach( (el) =>{\n\n//   el.addEventListener('mouseover', () => {\n//     console.log('Mouse is over the button');\n\n//     menuBtn.classList.add('hovered');\n//     let subList = el.querySelector('.subList');\n//     if (subList) {\n//       subList.classList.add('active');\n//     }\n\n// });\n\n// el.addEventListener('mouseout', () => {\n\n//   console.log('Mouse is not over the button');\n\n//   let subList = el.querySelector('.subList');\n//   if (subList) {\n//     subList.classList.remove('active');\n//   }\n\n// });\n// })\n\ndocument.addEventListener(\"DOMContentLoaded\", function () {\n  if (desktop.matches) {\n    // console.log(\"desktop\");\n\n    const footer = document.querySelector(\".footer\");\n    const lastCard = document.querySelector(\".section.last\");\n\n    const pinnedSection = gsap.utils.toArray(\".pinned\");\n\n    pinnedSection.forEach((section, index, sections) => {\n      let img = section.querySelector(\".div\");\n\n      let nextSection = sections[index + 1] || lastCard;\n\n      let endScalePoint = `top+=${nextSection.offsetTop - section.offsetTop\n        } top`;\n\n      gsap.to(section, {\n        scrollTrigger: {\n          trigger: section,\n          start: \"top top\",\n          end:\n            index === sections.length\n              ? `-${lastCard.offsetHeight / 2}`\n              : footer.offsetTop - window.innerHeight,\n          pin: true,\n          pinSpacing: false,\n          scrub: 1,\n        },\n      });\n\n      gsap.fromTo(\n        img,\n        { scale: 1, opacity: 1 },\n        {\n          scale: 0.5,\n          opacity: 0,\n          ease: \"none\",\n          scrollTrigger: {\n            trigger: section,\n            start: \" top top\",\n            end: endScalePoint,\n            scrub: 1,\n          },\n        }\n      );\n    });\n  }\n\n\n  gsap.utils.toArray(\".dot-space\").forEach((dotSpace) => {\n    const tl = gsap.timeline({\n      scrollTrigger: {\n        trigger: dotSpace,\n        start: \"top center\",\n        end: \"bottom center\",\n        scrub: 1,\n        once: true\n      }\n    });\n\n\n    gsap.utils.toArray(\"circle\", dotSpace).forEach((circle, index) => {\n      tl.fromTo(circle,\n        { opacity: 0, scale: 0 },\n        { opacity: 1, scale: 1, duration: 0.3, ease: \"power1.out\" },\n        index * 0.2\n      );\n    });\n  });\n\n\n\n\n  let slideAnimation3 = document.querySelectorAll(\".slide_animation_3\");\n\n  if (slideAnimation3) {\n    slideAnimation3.forEach((block) => {\n      let tl = gsap.timeline({\n        scrollTrigger: {\n          trigger: block,\n          // markers: true,\n          start: \"top 60%\",\n          toggleActions: \"play none none none\",\n        },\n      });\n\n      tl.from(block.querySelectorAll(\".block\"), {\n        opacity: 0,\n        y: 40,\n        duration: 1.2,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        delay: 0.1,\n      });\n    });\n  }\n\n  //! blogs ajax View more \n\n\n\n  let blogsViewMore = document.querySelector('#blogsViewMore');\n  let blogsCount = 3; // Initialize count outside to retain its value\n\n\n\n\n\n  if (blogsViewMore) {\n    fetchBlogs(blogsCount);\n  }\n\n  function fetchBlogs(postsPerPage) {\n    const resultsContainer = document.querySelector('#blog-container');\n\n    jQuery.ajax({\n      type: 'post',\n      url: `${window.location.origin}/wp-admin/admin-ajax.php`,\n      data: {\n        action: 'blogViewMore',\n        ajax_data: {\n          postCount: postsPerPage,\n\n\n        },\n      },\n      beforeSend: function () {\n        // Add loading text before the request\n        if (resultsContainer) {\n          resultsContainer.innerHTML += `\n                    <img \n                        src=\"https://ncaer.greatestdesignever.com/wp-content/themes/ncaer/assets2/images/reserachVertical/loading-gif.gif\" \n                        alt=\"Loading...\" \n                        style=\"\n                            width: 3rem; \n                            position: absolute; \n                            left: 50%; \n                            transform: translate(-50%, 0%);\n                        \" \n                    />\n                `;\n        }\n      },\n      complete: function (response) {\n        // console.log(response);\n\n        if (resultsContainer) {\n          resultsContainer.innerHTML = ''; // Clear existing posts\n        }\n\n        // Ensure responseJSON is defined before checking its properties\n        const responseData = response.responseJSON;\n\n        if (responseData && Array.isArray(responseData.posts)) {\n          if (responseData.posts.length > 0) {\n            responseData.posts.forEach(post => {\n              const cardTemplate = `\n                               \n  <a href=\"${post.Url}\" class=\"block\">\n\n            <img src=\" ${post.thumbnail}\" alt=\"\">\n            <h1>\n            ${post.title}\n            </h1>\n         \n            <p class=\"date\"> ${post.postDate} </p>\n        </a>\n\n                        `;\n\n              if (resultsContainer) {\n                resultsContainer.innerHTML += cardTemplate;\n              }\n            });\n\n            // Check if there are more posts to load\n            if (!responseData.more_posts) {\n              blogsViewMore.style.display = 'none'; // Hide the \"View More\" button\n            }\n          } else {\n            // If no posts were found, display a message\n            if (resultsContainer) {\n              resultsContainer.innerHTML = '<p>No posts found.</p>';\n            }\n          }\n        } else {\n          // Handle case where responseJSON is null or doesn't contain posts\n          if (resultsContainer) {\n            resultsContainer.innerHTML = '';\n            blogsViewMore.style.display = 'none';\n\n          }\n        }\n      }\n    });\n  }\n\n  blogsViewMore?.addEventListener('click', function (e) {\n    // console.log('clicked');\n\n    e.preventDefault();\n    blogsCount += 3;\n    fetchBlogs(blogsCount);\n    smoother.paused(true);\n\n    const isActive = blogsCount;\n\n    const delay = isActive ? 700 : 300;\n\n    setTimeout(() => {\n      debounceRefresh(() => {\n        ScrollTrigger.refresh();\n        smoother.paused(false);\n      }, 100);\n    }, delay);\n\n\n\n  });\n\n\n\n  // blogs listing page debounce\n\n\n\n\n  // const blogContainer = document.querySelector(\".blogsViewMore h1\");\n\n  // blogContainer.addEventListener(\"click\", function (e) {\n\n  // });\n\n\n\n  \nconst ourCoreGallery = new Swiper('.ourCore_gallery', {\n  initialSlide: 0,\n  slidesPerView: 1,         // default for mobile\n  spaceBetween: 10,\n  centeredSlides: false,\n  loop: true,\n  // grabCursor: true,\n  speed: 600,\n  slideToClickedSlide: true,\n\t\n\tautoplay: {\n    delay: 3000, // time between slides in milliseconds (e.g., 3 seconds)\n    disableOnInteraction: false, // keeps autoplay running after user interaction\n  },\n  breakpoints: {\n    768: {                  // from 768px and above\n      slidesPerView: 3,\n      spaceBetween: 30,\n      centeredSlides: true,\n    }\n  }\n});\n\n\n$(\".ourCore_gallery .slideNav .prev\").click(function () {\n  ourCoreGallery.slidePrev();\n});\n\n$(\".ourCore_gallery .slideNav .next\").click(function () {\n  ourCoreGallery.slideNext();\n});\n\n\n\n\n  lightGallery(document.getElementById('lightgallery'), {\n    selector: 'a',\n    plugins: [lgThumbnail],\n    thumbnail: true,\n    download: false,\n  });\n\n\n\n\n});\n    \n\t\n// !emt top features \n\n$(\".emt-topfeatures .slides\").slick({\n  infinite: true,\n  slidesToShow: 3,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 2,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".emt-topfeatures .slideNav .prev\").click(function () {\n  $(\".emt-topfeatures .slides\").slick(\"slickPrev\");\n});\n$(\".emt-topfeatures .slideNav .next\").click(function () {\n  $(\".emt-topfeatures .slides\").slick(\"slickNext\");\n});\n\n\n// !rtu why choose \n\n\n$(\".emt-how-it-help .slides\").slick({\n  infinite: true,\n  slidesToShow: 3,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 2,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".emt-how-it-help .slideNav .prev\").click(function () {\n  $(\".emt-how-it-help .slides\").slick(\"slickPrev\");\n});\n$(\".emt-how-it-help .slideNav .next\").click(function () {\n  $(\".emt-how-it-help .slides\").slick(\"slickNext\");\n});\n\n\n\n// !emt why-choose slide \n\n$(\".emt-why-choose .slides\").slick({\n  infinite: true,\n  slidesToShow: 3,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 2,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".emt-why-choose .slideNav .prev\").click(function () {\n  $(\".emt-why-choose .slides\").slick(\"slickPrev\");\n});\n$(\".emt-why-choose .slideNav .next\").click(function () {\n  $(\".emt-why-choose .slides\").slick(\"slickNext\");\n});\n\n\n\n\n\n$(\".resources-blog-slide .slides\").slick({\n  infinite