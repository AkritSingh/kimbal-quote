l: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".rtu-topfeatures .slideNav .prev\").click(function () {\n  $(\".rtu-topfeatures .slides\").slick(\"slickPrev\");\n});\n$(\".rtu-topfeatures .slideNav .next\").click(function () {\n  $(\".rtu-topfeatures .slides\").slick(\"slickNext\");\n});\n\n\n// !rtu why choose \n\n\n$(\".rtu-why-choose .slides\").slick({\n  infinite: true,\n  slidesToShow: 3,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 2,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".rtu-why-choose .slideNav .prev\").click(function () {\n  $(\".rtu-why-choose .slides\").slick(\"slickPrev\");\n});\n$(\".rtu-why-choose .slideNav .next\").click(function () {\n  $(\".rtu-why-choose .slides\").slick(\"slickNext\");\n});\n\n\n\n\n\n\n// !nice slider \n\n\n$(\".nic_slides .slides\").slick({\n  infinite: true,\n  slidesToShow: 3,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 1,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".nic_slides .slideNav .prev\").click(function () {\n  $(\".nic_slides .slides\").slick(\"slickPrev\");\n});\n$(\".nic_slides .slideNav .next\").click(function () {\n  $(\".nic_slides .slides\").slick(\"slickNext\");\n});\n\n\n\n\n// ! rh_mesh page ======================\n\n$(\".rh_mesh-whyChooseVayu .slides\").slick({\n  infinite: true,\n  slidesToShow: 3,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 1,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".rh_mesh-whyChooseVayu .slideNav .prev\").click(function () {\n  $(\".rh_mesh-whyChooseVayu .slides\").slick(\"slickPrev\");\n});\n$(\".rh_mesh-whyChooseVayu .slideNav .next\").click(function () {\n  $(\".rh_mesh-whyChooseVayu .slides\").slick(\"slickNext\");\n});\n\n//! consumer_mobile_app page ================\n\n$(\".consumer_mobile_app-whyChooseVayu .slides\").slick({\n  infinite: true,\n  slidesToShow: 3,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 1,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".consumer_mobile_app-whyChooseVayu .slideNav .prev\").click(function () {\n  $(\".consumer_mobile_app-whyChooseVayu .slides\").slick(\"slickPrev\");\n});\n$(\".consumer_mobile_app-whyChooseVayu .slideNav .next\").click(function () {\n  $(\".consumer_mobile_app-whyChooseVayu .slides\").slick(\"slickNext\");\n});\n\n// ! smart_meters page =============================\n\n//! main nav \nlet slideTab = document.querySelectorAll(\".smart_meters-slides .nav .tab\");\nlet allTextContainer = document.querySelectorAll('.smart_meters-slides  .container_1 > .text > h1');\nlet allTabSlider = document.querySelectorAll('.smart_meters-slides .container_1 .slider')\nlet allTabImages = document.querySelectorAll('.smart_meters-slides .container_2 img')\nlet allPopUpSlide = document.querySelectorAll('.smart_meters-slides .container_3 .popUpBlock')\nlet allTextImageTab = document.querySelectorAll('.smart_meters-textImageTab')\n\n\n\n\n\n\n\n//! initial load \n\nslideTab[0]?.classList.add(\"active\");\nallTextContainer[0]?.classList.add(\"active\");\nallTabSlider[0]?.classList.add(\"active\");\nallTabImages[0]?.classList.add(\"active\");\nallPopUpSlide[0]?.classList.add(\"active\");\nallTextImageTab[0]?.classList.add(\"active\");\n\n\n\nslideTab?.forEach(function (el, index) {\n  el.addEventListener(\"click\", function () {\n\n\n\n\n    //! cleare all classes \n\n    // tab \n    slideTab.forEach(function (el) {\n      el.classList.remove(\"active\");\n    });\n\n    // text \n\n    allTextContainer.forEach(function (el) {\n      el.classList.remove(\"active\");\n    });\n\n    // slider \n\n\n    allTabSlider.forEach(function (el) {\n      el.classList.remove(\"active\");\n    });\n\n    // image \n    allTabImages.forEach(function (el) {\n      el.classList.remove(\"active\");\n    });\n\n    // popup slide slide \n    allPopUpSlide.forEach(function (el) {\n      el.classList.remove(\"active\");\n    });\n\n\n    // textImageTabs \n    allTextImageTab.forEach(function (el) {\n      el.classList.remove(\"active\");\n    });\n\n\n\n    // !add classes \n\n    // tab \n    slideTab[index].classList.add(\"active\");\n\n    // text \n\n    allTextContainer[index].classList.add('active')\n\n    // slider \n\n    allTabSlider[index].classList.add('active')\n\n\n    // image\n\n    allTabImages[index].classList.add('active')\n\n    // popup slide \n    allPopUpSlide[index].classList.add('active')\n\n\n    // textImageTabs \n\n    allTextImageTab[index].classList.add('active')\n\n    // !refresh slick slider \n\n    $('.smart_meters-topFeatures .slides').slick('refresh');\n\n\n    $('.smart_meters-slides .container_1 .slider').slick('refresh');\n\n\n\n\n  });\n});\n\n\n\n\n\n\n\n// !==============================================\n\n//! slick slide\n\n//! smart meter new slider with tabs \n$(\".smart_meters-slides  .slider\").slick({\n  infinite: true,\n  slidesToShow: 3,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 2, // Show 2 slides between 481px and 768px\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n    {\n      breakpoint: 480,\n      settings: {\n        slidesToShow: 1, // Show 1 slide at 480px and below\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".smart_meters-slides  .slideNav .prev\").click(function () {\n  $(\".smart_meters-slides  .slider\").slick(\"slickPrev\");\n});\n$(\".smart_meters-slides  .slideNav .next\").click(function () {\n  $(\".smart_meters-slides  .slider\").slick(\"slickNext\");\n});\n\n\n\n\n\nif (mobile.matches) {\n\n\n\n  $('.nilmKey .slides').slick({\n    slidesToShow: 1,\n    slidesToScroll: 1,\n    autoplay: true,\n    autoplaySpeed: 3000,\n    dots: false,\n    arrows: false,\n    infinite: true,\n    speed: 500,\n    fade: false,\n    cssEase: 'linear'\n  });\n\n}\n\n\nif (mobile.matches) {\n\n\n\n  $('.nilmBills .blockContainer').slick({\n    slidesToShow: 1,\n    slidesToScroll: 1,\n    autoplay: true,\n    autoplaySpeed: 3000,\n    dots: false,\n    arrows: false,\n    infinite: true,\n    speed: 500,\n    fade: false,\n    cssEase: 'linear'\n  });\n\n}\n\n\n\n\n\n\n\n$(\".smart_meters-topFeatures .slides\").slick({\n  infinite: true,\n  slidesToShow: 3,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 2, // Show 2 slides between 481px and 768px\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n    {\n      breakpoint: 480,\n      settings: {\n        slidesToShow: 1, // Show 1 slide at 480px and below\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".smart_meters-topFeatures .slideNav .prev\").click(function () {\n  $(\".smart_meters-topFeatures .slides\").slick(\"slickPrev\");\n});\n$(\".smart_meters-topFeatures .slideNav .next\").click(function () {\n  $(\".smart_meters-topFeatures .slides\").slick(\"slickNext\");\n});\n\n\n\n// !nic top features \n\n//! slick slide\n\n$(\".nic-topFeatures .slides\").slick({\n  infinite: true,\n  slidesToShow: 3,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 781,\n      settings: {\n        slidesToShow: 2, // Show 2 slides between 481px and 768px\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n    {\n      breakpoint: 600,\n      settings: {\n        slidesToShow: 1, // Show 1 slide at 480px and below\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".nic-topFeatures .slideNav .prev\").click(function () {\n  $(\".nic-topFeatures .slides\").slick(\"slickPrev\");\n});\n$(\".nic-topFeatures .slideNav .next\").click(function () {\n  $(\".nic-topFeatures .slides\").slick(\"slickNext\");\n});\n\n\n// !work force page ===================\n\n$(\".workforce-specialFeatures .slides\").slick({\n  infinite: true,\n  slidesToShow: 3,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 1,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".workforce-specialFeatures .slideNav .prev\").click(function () {\n  $(\".workforce-specialFeatures .slides\").slick(\"slickPrev\");\n});\n$(\".workforce-specialFeatures .slideNav .next\").click(function () {\n  $(\".workforce-specialFeatures .slides\").slick(\"slickNext\");\n});\n\n\n$(\".workforce-benefits .slides\").slick({\n  infinite: true,\n  slidesToShow: 3,\n  slidesToScroll: 1,\n  arrows: false,\n  autoplay: true,\n  autoplaySpeed: 3000,\n  responsive: [\n    {\n      breakpoint: 768,\n      settings: {\n        slidesToShow: 1,\n        slidesToScroll: 1,\n        infinite: true,\n      },\n    },\n  ],\n});\n\n$(\".workforce-benefits .slideNav .prev\").click(function () {\n  $(\".workforce-benefits .slides\").slick(\"slickPrev\");\n});\n$(\".workforce-benefits .slideNav .next\").click(function () {\n  $(\".workforce-benefits .slides\").slick(\"slickNext\");\n});\n\n\n// !jobbs slider \n\n\nif (mobile.matches) {\n\n\n\n  $(\".post-container .latestJobs .content\").slick({\n    infinite: true,\n    slidesToShow: 1,\n    slidesToScroll: 1,\n    arrows: false,\n    autoplay: true,\n    autoplaySpeed: 3000,\n    responsive: [\n      {\n        breakpoint: 768,\n        settings: {\n          slidesToShow: 1,\n          slidesToScroll: 1,\n          infinite: true,\n        },\n      },\n    ],\n  });\n\n  $(\".latestJobs  .slideNav .prev\").click(function () {\n    $(\".latestJobs   .content\").slick(\"slickPrev\");\n  });\n  $(\".latestJobs  .slideNav .next\").click(function () {\n    $(\".latestJobs   .content\").slick(\"slickNext\");\n  });\n\n}\n\n\n\n\n// !careers page======================\n\n// ! popup section\n\nlet careersBlock = document.querySelectorAll(\".careers-blocks .block \");\n\ncareersBlock.forEach(function (block) {\n  block.addEventListener(\"click\", function (el) {\n    let popUp = this.querySelector(\".content\");\n\n    if (popUp) {\n      popUp.classList.add(\"active\");\n      setTimeout(() => {\n        popUp.style.opacity = \"1\";\n      }, 100);\n    }\n  });\n});\n\n// !close popUp\n\nlet careersBlockCloseBtn = document.querySelectorAll(\n  \".careers-blocks .block .close\"\n);\n\ncareersBlockCloseBtn.forEach(function (element) {\n  element.addEventListener(\"click\", function (el) {\n    el.stopPropagation();\n\n    let popUp = this.parentElement;\n\n    popUp.style.opacity = \"0\";\n\n    setTimeout(() => {\n      popUp.classList.remove(\"active\");\n    }, 300);\n  });\n});\n\n// ! hiring slides ============\n\nlet careerSlideTab = document.querySelectorAll(\".careers-hiring .nav .tab\");\n\nlet careerAllTabs = document.querySelectorAll(\n  \".careers-hiring .container .slide\"\n);\n\ncareerSlideTab[0]?.classList.add(\"active\");\n\ncareerAllTabs[0]?.classList.add(\"active\");\n\ncareerSlideTab.forEach(function (el, index) {\n  el.addEventListener(\"click\", function () {\n    careerAllTabs.forEach(function (el) {\n      el.classList.remove(\"active\");\n    });\n\n    careerSlideTab.forEach(function (el) {\n      el.classList.remove(\"active\");\n    });\n\n    careerAllTabs[index].classList.add(\"active\");\n    careerSlideTab[index].classList.add(\"active\");\n  });\n});\n\n// !wordpress popup ====================\n\n// !ourStory readmore popUp\n\nlet ourStoryBlock = document.querySelectorAll(\n  \".ourStory_testimonials .slides .block a\"\n);\n\n// console.log(ourStoryBlock);\n\nourStoryBlock?.forEach(function (block) {\n  block.addEventListener(\"click\", function (el) {\n    el.preventDefault();\n\n    let head = this.parentElement.querySelector(\"h1\").innerHTML;\n    let para = this.parentElement.querySelector(\"p\").innerHTML;\n\n\n\n    let popUp = document.querySelector(\".ourStoryReadMore-popUps\");\n\n    popUpHead = popUp.querySelector(\".head h1\");\n    popUpPara = popUp.querySelector(\".content p\");\n\n\n    popUpHead.innerHTML = head;\n    popUpPara.innerHTML = para;\n\n    if (popUp) {\n      popUp.classList.add(\"active\");\n      popUp.parentElement.style.display = 'block';\n\n      setTimeout(() => {\n        popUp.style.opacity = \"1\";\n        popUp.parentElement.style.opacity = \"1\";\n\n      }, 100);\n    }\n  });\n});\n\n// popUp closeBtn =============\n\nlet ourStoryPopUpCloseBtn = document.querySelector(\n  \".ourStoryReadMore-popUps .closeBtn\"\n);\n\nourStoryPopUpCloseBtn?.addEventListener(\"click\", function () {\n  popUp = this.parentElement;\n  popUp.style.opacity = \"0\";\n  popUp.parentElement.style.opacity = \"0\";\n\n  setTimeout(() => {\n    popUp.classList.remove(\"active\");\n    popUp.parentElement.style.display = 'none';\n  }, 300);\n});\n\n\n// !our plants \n\n//! block popUp \n\nlet ourPlantsBlock = document.querySelectorAll(\n  \".ourPlants-blocks .block\"\n);\n\n// console.log(ourStoryBlock);\n\nourPlantsBlock.forEach(function (block) {\n  block.addEventListener(\"click\", function (el) {\n    el.preventDefault();\n\n    let head = this.querySelector(\".popUp h1\").innerHTML;\n    // let para = this.querySelector(\".popUp p\").innerHTML;\n    let label1 = this.querySelector('.popUp .text_1 h1').innerHTML;\n    let label2 = this.querySelector('.popUp .text_2 h1').innerHTML;\n    let image = this.querySelector('.popUp .c1 img').src;\n\n\n    let title = this.querySelector('.popUp .c2 h1').innerHTML;\n    let list = this.querySelectorAll('.popUp .c2 li');\n\n\n    // console.log(head, para ,label1 ,label2 , title, list ,image);\n\n\n    //! adding all the content \n    let popUp = document.querySelector(\".ourPlants-block-popUp\");\n\n\n\n    let popUpHead = popUp.querySelector(\"h1\");\n    let popUpPara = popUp.querySelector(\" p\");\n    let popUpTitle = popUp.querySelector(\" .c2 h1\");\n    let popUpLabel1 = popUp.querySelector(\".text_1 h1\");\n    let popUpLabel2 = popUp.querySelector(\".text_2 h1\");\n    let popUpImage = popUp.querySelector(\".c1 img\");\n    let popUpList = popUp.querySelector('.c2 ul');\n\n\n    popUpHead.innerHTML = head;\n    // popUpPara.innerHTML = para;\n    popUpLabel1.innerHTML = label1;\n    popUpLabel2.innerHTML = label2;\n    popUpImage.src = image;\n    popUpTitle.innerHTML = title;\n\n    list.forEach((li) => {\n      let clonedLi = li.cloneNode(true);\n      popUpList.appendChild(clonedLi);\n    });\n\n    if (popUp) {\n      popUp.classList.add(\"active\");\n      popUp.parentElement.style.display = 'block';\n\n\n      setTimeout(() => {\n        popUp.style.opacity = \"1\";\n        popUp.parentElement.style.opacity = \"1\";\n      }, 100);\n    }\n  });\n});\n\n\nlet ourPlantsPopUpCloseBtn = document.querySelector(\n  \".ourPlants-block-popUp .closeBtn\"\n);\n\nourPlantsPopUpCloseBtn?.addEventListener(\"click\", function () {\n\n\n  let popUp = document.querySelector(\".ourPlants-block-popUp\");\n\n  //! clearing all the content \n\n\n\n\n  let popUpHead = popUp.querySelector(\" h1\");\n  let popUpPara = popUp.querySelector(\"  p\");\n  let popUpTitle = popUp.querySelector(\"  .c2 h1\");\n  let popUpLabel1 = popUp.querySelector(\" .text_1 h1\");\n  let popUpLabel2 = popUp.querySelector(\" .text_2 h1\");\n  let popUpImage = popUp.querySelector(\" .c1 img\");\n  let popUpList2 = popUp.querySelectorAll(' .c2 ul ')\n\n\n\n  popUpHead.innerHTML = '';\n  popUpPara.innerHTML = '';\n  popUpTitle.innerHTML = '';\n  popUpLabel1.innerHTML = '';\n  popUpLabel2.innerHTML = '';\n  popUpImage.src = '';\n\n  popUpList2.forEach(ul => {\n    // Remove all 'li' elements inside this 'ul'\n    while (ul.firstChild) {\n      ul.removeChild(ul.firstChild);\n    }\n  });\n\n\n  popUp = this.parentElement;\n  popUp.style.opacity = \"0\";\n  popUp.parentElement.style.opacity = \"0\";\n\n  setTimeout(() => {\n\n    popUp.classList.remove(\"active\");\n    popUp.parentElement.style.display = 'none';\n  }, 300);\n});\n\n\n//! slide  popUp \n\n\nlet ourPlantsSlide = document.querySelectorAll(\n  \".ourPlants-distinguishingFactor .slide .block\"\n);\n\n// console.log(ourStoryBlock);\n\nourPlantsSlide.forEach(function (block) {\n  block.addEventListener(\"click\", function (el) {\n    el.preventDefault();\n\n    let head = this.querySelector(\" .content h2\").innerHTML;\n\n\n    let image = this.querySelector('.image img').src;\n    let list = this.querySelectorAll('.content li');\n\n\n    // console.log(head,    list ,image);\n\n    //! adding all the content \n    let popUp = document.querySelector(\".ourPlants-slide-popUp\");\n\n\n\n    let popUpHead = popUp.querySelector(\".c2 h1\");\n\n    let popUpImage = popUp.querySelector('.c1 img');\n    let popUpList = popUp.querySelector(\" .c2 ul\");\n\n    popUpHead.innerHTML = head;\n    popUpImage.src = image;\n\n    list.forEach((li) => {\n      let clonedLi = li.cloneNode(true);\n      clonedLi.style.display = 'block';\n      popUpList.appendChild(clonedLi);\n    });\n\n\n    if (popUp) {\n      popUp.classList.add(\"active\");\n      popUp.parentElement.style.display = 'block';\n      setTimeout(() => {\n        popUp.style.opacity = \"1\";\n        popUp.parentElement.style.opacity = \"1\";\n      }, 100);\n    }\n\n  })\n})\n\n// !close btn \n\nlet ourPlantsSlidePopUpCloseBtn = document.querySelector(\n  \".ourPlants-slide-popUp .closeBtn\"\n);\nourPlantsSlidePopUpCloseBtn?.addEventListener(\"click\", function () {\n\n\n  let popUp = document.querySelector(\".ourPlants-slide-popUp\");\n\n  let popUpHead = popUp.querySelector(\" .c2 h1\");\n\n  let popUpImage = popUp.querySelector(' .c1 img');\n  let popUpList = popUp.querySelectorAll(\" .c2 ul \");\n\n  popUpHead.innerHTML = ''\n  popUpImage.src = ''\n\n  popUpList.forEach(ul => {\n    // Remove all 'li' elements inside this 'ul'\n    while (ul.firstChild) {\n      ul.removeChild(ul.firstChild);\n    }\n  });\n\n\n  popUp = this.parentElement;\n  popUp.style.opacity = \"0\";\n  popUp.parentElement.style.opacity = \"0\";\n  setTimeout(() => {\n    popUp.classList.remove(\"active\");\n    popUp.parentElement.style.display = 'none';\n  }, 300);\n\n})\n\n\n// !careers popUp \n\n\n//! slide  popUp \n\n\nlet careersSlide = document.querySelectorAll(\n  \".careers-blocks .block\"\n);\n\n// console.log(ourStoryBlock);\n\ncareersSlide.forEach(function (block) {\n  block.addEventListener(\"click\", function (el) {\n    el.preventDefault();\n\n    let head = this.querySelector(\" .head h1\").innerHTML;\n\n\n    let head2 = this.querySelector('.content .container h2').innerHTML;\n    let para = this.querySelector('.content .container p').innerHTML;\n\n\n    // console.log(head,    head2 ,para);\n\n    //! adding all the content \n\n    let popUp = document.querySelector(\".careers-block-popUp\");\n\n\n\n    let popUpHead = popUp.querySelector(\".container h1\");\n\n    let popUpHead2 = popUp.querySelector('.container h2');\n    let popUpPara = popUp.querySelector(\" .container p\");\n\n    popUpHead.innerHTML = head;\n    popUpHead2.innerHTML = head2;\n    popUpPara.innerHTML = para;\n\n\n\n\n\n    if (popUp) {\n      popUp.classList.add(\"active\");\n      popUp.parentElement.style.display = 'block';\n      setTimeout(() => {\n        popUp.style.opacity = \"1\";\n        popUp.parentElement.style.opacity = \"1\";\n      }, 100);\n    }\n\n  })\n})\n\n// !close btn \n\nlet careersSlideCloseBtn = document.querySelector(\n  \".careers-block-popUp .close\"\n);\ncareersSlideCloseBtn?.addEventListener(\"click\", function () {\n\n\n  let popUp = document.querySelector(\".careers-block-popUp\");\n\n  let popUpHead = popUp.querySelector(\".container h1\");\n\n  let popUpHead2 = popUp.querySelector('.container h2');\n  let popUpPara = popUp.querySelector(\" .container p\");\n\n  popUpHead.innerHTML = ''\n  popUpHead2.innerHTML = ''\n  popUpPara.innerHTML = ''\n\n\n\n  popUp = this.parentElement;\n  popUp.style.opacity = \"0\";\n  popUp.parentElement.style.opacity = \"0\";\n  setTimeout(() => {\n    popUp.classList.remove(\"active\");\n    popUp.parentElement.style.display = 'none';\n  }, 300);\n\n})\n\n\n\n\n// !gsap ====================================================================\n\n//! animation defaults\n\n// !slide animation 1 =======================\n\nlet slideAnimation1 = document.querySelectorAll(\".slide_animation_1\");\n\nif (slideAnimation1) {\n  slideAnimation1.forEach((block) => {\n    let tl = gsap.timeline({\n      scrollTrigger: {\n        trigger: block,\n        // markers: true,\n        start: \"top 60%\",\n        toggleActions: \"play none none none\",\n      },\n    });\n\n    tl.from(block.querySelector(\"h1\"), {\n      opacity: 0,\n      y: 40,\n      duration: 1.2,\n      stagger: 0.2,\n      ease: \"power2.out\",\n      delay: 0.1,\n    })\n      .from(\n        block.querySelector(\" h2 \"),\n        {\n          opacity: 0,\n          y: 40,\n          duration: 1.2,\n          stagger: 0.2,\n          ease: \"power2.out\",\n          delay: 0.1,\n        },\n        \"<\"\n      )\n\n      .from(\n        block.querySelector(\" h2 img\"),\n        {\n          opacity: 0,\n          y: 40,\n          duration: 1.2,\n          stagger: 0.2,\n          ease: \"power2.out\",\n          delay: 0.1,\n        },\n        \"<\"\n      )\n      .from(\n        block.querySelector(\"div > img\"),\n        {\n          opacity: 0,\n          y: 40,\n          duration: 1.2,\n          stagger: 0.2,\n          ease: \"power2.out\",\n          delay: 0.1,\n        },\n        \"<\"\n      )\n\n      .from(\n        block.querySelector(\" h3\"),\n        {\n          opacity: 0,\n          y: 40,\n          duration: 1.2,\n          stagger: 0.2,\n          ease: \"power2.out\",\n          delay: 0.1,\n        },\n        \"<\"\n      )\n\n\n      .from(\n        block.querySelector(\" .text\"),\n        {\n          opacity: 0,\n          y: 40,\n          duration: 1.2,\n          stagger: 0.2,\n          ease: \"power2.out\",\n          delay: 0.1,\n        },\n        \"<\"\n      );\n  });\n}\n\n// !slide animation 1 =======================\n\nlet slideAnimation2 = document.querySelectorAll(\".slide_animation_2\");\n\nif (slideAnimation2) {\n  slideAnimation2.forEach((block) => {\n    let tl = gsap.timeline({\n      scrollTrigger: {\n        trigger: block,\n        // markers: true,\n        start: \"top 60%\",\n        toggleActions: \"play none none none\",\n      },\n    });\n\n    tl.from(block.querySelector(\"h1\"), {\n      opacity: 0,\n      y: 40,\n      duration: 1.2,\n      stagger: 0.2,\n      ease: \"power2.out\",\n      delay: 0.1,\n    })\n\n      .from(\n        block.querySelector(\" h1 img\"),\n        {\n          opacity: 0,\n          y: 40,\n          duration: 1.2,\n          stagger: 0.2,\n          ease: \"power2.out\",\n          delay: 0.1,\n        },\n        \"<\"\n      )\n\n      .from(\n        block.querySelector(\" h2\"),\n        {\n          opacity: 0,\n          y: 40,\n          duration: 1.2,\n          stagger: 0.2,\n          ease: \"power2.out\",\n          delay: 0.1,\n        },\n        \"<\"\n      );\n  });\n}\n\n// !block list animation\n\nlet blockListAnimation = document.querySelectorAll(\"